# Required for JWT signing (use a long random string in production)
JWT_SECRET=change-it-to-a-long-random-secret

# Access token lifetime in seconds (default 28800 = 8h)
JWT_EXPIRES_SEC=28800

# SQLite file path (relative to repo root or absolute)
DB_PATH=data/taskmgmt.sqlite

# API port
PORT=3000

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:4200
